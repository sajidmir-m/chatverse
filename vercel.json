{
  "version": 2,
  "installCommand": "npm install --include=dev --prefix client && npm install --include=dev --prefix server",
  "buildCommand": "npm run vercel-build --prefix server",
  "build": {
    "env": {
      "NPM_CONFIG_PRODUCTION": "false"
    }
  },
  "builds": [
    {
      "src": "server/vercel.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "public/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server/vercel.js" }
  ]
}
