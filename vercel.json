{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "installCommand": "npm install --include=dev --prefix client && npm install --include=dev --prefix server",
  "buildCommand": "npm run vercel-build --prefix server",
  "functions": {
    "src/server.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/src/server.ts" },
    { "source": "/health", "destination": "/src/server.ts" },
    { "source": "/socket.io/(.*)", "destination": "/src/server.ts" }
  ]
}
