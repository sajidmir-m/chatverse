{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "installCommand": "npm install --include=dev --prefix client && npm install --include=dev --prefix server",
  "buildCommand": "npm run vercel-build --prefix server",
  "functions": {
    "server/vercel.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/vercel.js" },
    { "source": "/health", "destination": "/server/vercel.js" },
    { "source": "/socket.io/(.*)", "destination": "/server/vercel.js" },
    { "source": "/((?!api|health|socket\\.io|assets|favicon\\.svg).*)", "destination": "/index.html" }
  ]
}
