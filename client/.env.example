# Domain only — NEVER add /api at the end
# Wrong: https://your-app.vercel.app/api
# Right: https://your-app.vercel.app
VITE_API_URL=
VITE_SOCKET_URL=
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Separate backend deploy only:
# VITE_API_URL=https://your-backend.vercel.app
# VITE_SOCKET_URL=https://your-backend.vercel.app
# Google Auth setup (Supabase Dashboard):
# 1. Authentication -> Providers -> Google -> Enable
# 2. Add Google OAuth Client ID + Secret from Google Cloud Console
# 3. Authentication -> URL Configuration -> Redirect URLs:
#    - http://localhost:5173/auth/callback
#    - https://your-frontend.vercel.app/auth/callback
