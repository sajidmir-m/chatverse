# ─── LOCAL DEVELOPMENT (client/.env) ───
# VITE_ = read by React/Vite in the browser
# Leave API URLs empty — auto uses http://localhost:3000

VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ─── PRODUCTION (Vercel dashboard — NOT in git) ───
# Set these in Vercel → Settings → Environment Variables
# Then REDEPLOY (env is baked in at build time)
#
# Frontend (VITE_ prefix — required for React):
#   VITE_SUPABASE_URL=https://your-project.supabase.co
#   VITE_SUPABASE_ANON_KEY=your_anon_key
#   VITE_API_URL=          (leave EMPTY)
#   VITE_SOCKET_URL=       (leave EMPTY)
#
# Backend (no VITE_ prefix — for Express server):
#   SUPABASE_URL=https://your-project.supabase.co
#   SUPABASE_ANON_KEY=your_anon_key
#   SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#   CORS_ORIGIN=https://your-app.vercel.app
#   NODE_ENV=production
#
# Supabase → Authentication → URL Configuration:
#   Site URL: https://your-app.vercel.app
#   Redirect: https://your-app.vercel.app/auth/callback
#
# Google login also needs:
#   Supabase → Providers → Google → Enable + Save
#   Google Cloud → redirect: https://YOUR_PROJECT.supabase.co/auth/v1/callback
