{
  "name": "realtime-chat-backend",
  "version": "1.0.0",
  "description": "Real-time chat backend with Express, Socket.io, and Supabase",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx tsc",
    "build:client": "npm install --include=dev --prefix ../client && node scripts/prepare-client-env.mjs && npm run build --prefix ../client",
    "copy:client": "node scripts/copy-frontend.mjs",
    "vercel-build": "npm run build:client && npm run build && npm run copy:client",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit"
  },
  "keywords": ["chat", "socket.io", "express", "supabase"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
